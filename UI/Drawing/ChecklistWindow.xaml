<Window x:Class="ShipAutoCadPlugin.UI.ChecklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drawing QA/QC Checklist" Height="600" Width="700"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#FFF8F9FA" FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtHeader" Grid.Row="0" Text="Structure (Panel) Checklist" FontSize="18" FontWeight="Bold" Foreground="#FF005E9E" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgBar" Grid.Column="0" Height="20" Minimum="0" Maximum="100" Value="0" Foreground="#FF4CAF50" Background="#FFE0E0E0" BorderThickness="0"/>
            <TextBlock x:Name="TxtProgress" Grid.Column="1" Text="0 / 5 (0%)" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FF333333"/>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFEEEEEE" BorderThickness="0,0,0,1" Padding="5,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,10,0" Checked="CheckBox_Click" Unchecked="CheckBox_Click">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Content}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13" Foreground="#FF222222"/>
                                    
                                    <Button Grid.Column="2" Content="✕" Width="24" Height="24" Background="Transparent" Foreground="#FFD32F2F" BorderThickness="0" Cursor="Hand" FontWeight="Bold" ToolTip="Delete Custom Item"
                                            Visibility="{Binding IsCustom, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="BtnDeleteCustomItem_Click" Tag="{Binding Id}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtNewItem" Grid.Column="0" Height="28" Padding="5,0" VerticalContentAlignment="Center" Margin="0,0,10,0" Tag="Add custom check item here..."/>
            <Button x:Name="BtnAddItem" Grid.Column="1" Content="+ Add Custom Item" Height="28" Width="130" Background="#FFE1E1E1" BorderBrush="#FFADADAD" Cursor="Hand" Click="BtnAddItem_Click"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSaveDraft" Content="Save Draft" Height="32" Width="100" Background="#FFE1E1E1" BorderBrush="#FFADADAD" Cursor="Hand" Margin="0,0,10,0" Click="BtnSaveDraft_Click"/>
            <Button x:Name="BtnSignApprove" Content="SIGN &amp; APPROVE DRAWING" Height="32" Width="220" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSignApprove_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>