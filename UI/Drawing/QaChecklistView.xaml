<UserControl x:Class="ShipAutoCadPlugin.UI.QaChecklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF2F2F2"
             FontSize="11"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="DRAWING STATUS" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="15,10">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Current Status:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FF555555"/>
                    <Border Grid.Column="1" x:Name="BorderStatus" Background="#FFFFE0B2" BorderBrush="#FFFFB300" BorderThickness="1" CornerRadius="3" Padding="10,4" HorizontalAlignment="Left">
                        <TextBlock x:Name="TxtStatus" Text="PENDING / NOT STARTED" FontWeight="Bold" Foreground="#FFE65100"/>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Discipline / Type:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#FF555555"/>
                    <ComboBox Grid.Column="1" x:Name="CboDiscipline" Height="26" Width="200" HorizontalAlignment="Left"/>
                </Grid>

                <Grid x:Name="GridApprovedInfo" Margin="0,0,0,10" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Approved By:" FontWeight="SemiBold" Foreground="#FF555555"/>
                    <TextBlock Grid.Column="1" x:Name="TxtApprovedInfo" Text="User at Date" FontWeight="SemiBold" Foreground="#FF2E7D32"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button x:Name="BtnOpenChecklist" Content="OPEN QA/QC CHECKLIST" Height="32" Width="200" Background="#FF005E9E" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnOpenChecklist_Click" Margin="0,0,15,0"/>
            <Button x:Name="BtnReset" Content="Reset / Clear Data" Height="32" Width="130" Background="#FFE1E1E1" BorderBrush="#FFADADAD" Cursor="Hand" Click="BtnReset_Click"/>
        </StackPanel>
    </Grid>
</UserControl>