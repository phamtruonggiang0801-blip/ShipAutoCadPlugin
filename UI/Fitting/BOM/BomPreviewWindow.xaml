<Window x:Class="ShipAutoCadPlugin.UI.BomPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BOM Matrix Export &amp; Sync" Height="700" Width="1300"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#FFF2F2F2" FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <Style TargetType="Border" x:Key="ContainerBorderStyle">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFE1E1E1"/>
            <Setter Property="Foreground" Value="#FF111111"/>
            <Setter Property="BorderBrush" Value="#FFADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD0D0D0"/>
                    <Setter Property="BorderBrush" Value="#FF999999"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFBDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF005E9E"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF004C82"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF004C82"/>
                    <Setter Property="BorderBrush" Value="#FF003A63"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF003A63"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE8E8E8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="Foreground" Value="#FF222222"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#FF111111"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#FF000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ContainerBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Target BOM Type:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#FF444444"/>
                    
                    <RadioButton x:Name="RadioStructure" Content="Structure (Panel)" IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#FF222222"/>
                    <RadioButton x:Name="RadioHull" Content="Detail (Hull)" VerticalAlignment="Center" Foreground="#FF222222"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnScanDrawing" Content="Scan &amp; Count from Drawing" Width="220" Style="{StaticResource PrimaryButtonStyle}" Click="BtnScanDrawing_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource ContainerBorderStyle}" Padding="0">
            <DataGrid x:Name="GridBomMatrix" 
                      AutoGenerateColumns="True" 
                      CanUserAddRows="False" 
                      SelectionMode="Extended"
                      RowHeight="26"
                      AlternatingRowBackground="#FFFDFDFD"
                      HorizontalGridLinesBrush="#FFEEEEEE"
                      VerticalGridLinesBrush="#FFEEEEEE"
                      AutoGeneratingColumn="GridBomMatrix_AutoGeneratingColumn"
                      BorderThickness="0">
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtStatus" Grid.Column="0" Text="Ready to scan." VerticalAlignment="Center" FontStyle="Italic" Foreground="#FF666666"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnAutoBalloon" Content="Auto-Assign Positions" Width="170" Margin="0,0,8,0" Click="BtnAutoBalloon_Click"/>
                <Button x:Name="BtnSyncPosToCad" Content="Sync Pos to CAD" Width="150" Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSyncPosToCad_Click"/>
                <Button x:Name="BtnExportExcel" Content="Export to Excel" Width="140" Style="{StaticResource PrimaryButtonStyle}" Click="BtnExportExcel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>