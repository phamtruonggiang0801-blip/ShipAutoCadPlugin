<UserControl x:Class="ShipAutoCadPlugin.UI.FittingToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="11">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
        <StackPanel TextElement.FontWeight="Normal">
            
            <GroupBox Header="FITTING EXTRACTION (STEP 1)" Margin="5,0,5,10">
                <StackPanel Margin="0,4">
                    <TextBlock Text="Extract Model Geometry and Properties from Inventor IDW files into JSON/DWG." TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,10"/>
                    <Button x:Name="BtnBatchImportInventor" Content="Import .idw files" Click="BtnBatchImportInventor_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="FITTING FACTORY (STEP 2)" Margin="5,0,5,10">
                <StackPanel Margin="0,4">
                    <TextBlock Text="Harvest the extracted JSON files, split views, map layers, and inject attributes." TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,10"/>
                    
                    <Border Background="#FFF4F8FB" BorderBrush="#FFD2E3FC" BorderThickness="1" Padding="5" Margin="0,0,0,10" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="Set Target BOM Type:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#FF333333"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <RadioButton x:Name="RadioPanelFitting" Content="Panel (Structure)" IsChecked="True" Foreground="#FF0055A5" FontWeight="Bold" Margin="0,0,10,0"/>
                                <RadioButton x:Name="RadioDetailFitting" Content="Detail (Hull Matrix)" Foreground="#FF0055A5" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Button x:Name="BtnImportJson" Content="Import .json files" Click="BtnImportJson_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="FITTING LIBRARY (STEP 3)" Margin="5,0,5,10" BorderBrush="#FF0055A5" BorderThickness="2">
                <StackPanel Margin="0,4">
                    <TextBlock Text="Search, view, and insert standard fittings from the Central Library." TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,10"/>
                    <Button x:Name="BtnOpenLibrary" Content="🔍 OPEN FITTING LIBRARY" Height="30" FontWeight="Bold" Background="#FF0055A5" Foreground="White" Click="BtnOpenLibrary_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="BOM EXPORT (STEP 4)" Margin="5,0,5,10" BorderBrush="#FF28A745" BorderThickness="2">
                <StackPanel Margin="0,4">
                    <TextBlock Text="Scan drawings, count fittings, auto-assign balloons, and export BOM matrix to Excel." TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,10"/>
                    <Button x:Name="BtnOpenBomPreview" Content="OPEN BOM EXPORT" Height="30" FontWeight="Bold" Background="#FF28A745" Foreground="White" Click="BtnOpenBomPreview_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="BLOCK UTILITIES" Margin="5,0,5,10">
                <StackPanel Margin="0,4">
                    <TextBlock Text="Modify existing blocks without breaking references. Sync, replace, add or extract nested entities on the fly." TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,10"/>
                    
                    <Button x:Name="BtnRedefineBlocks" Content="Sync/Redefine Blocks" Margin="0,0,0,6" Click="BtnRedefineBlocks_Click"/>
                    <Button x:Name="BtnSmartReplace" Content="Smart Replace (Spatial)" Margin="0,0,0,6" Click="BtnSmartReplace_Click"/>
                    
                    <Button x:Name="BtnChangeBasePoint" Content="Change Insertion Point" Margin="0,0,0,6" Click="BtnChangeBasePoint_Click"/>
                    <Button x:Name="BtnAddToBlock" Content="Add Objects to Block" Margin="0,0,0,6" Click="BtnAddToBlock_Click"/>
                    <Button x:Name="BtnExtractFromBlock" Content="Extract Objects from Block" Click="BtnExtractFromBlock_Click"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>