<Window x:Class="ShipAutoCadPlugin.UI.NewAccessoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Accessory" Height="400" Width="350"
        WindowStartupLocation="CenterOwner" Topmost="True"
        Background="#FFF2F2F2" FontFamily="Segoe UI" FontSize="12">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Part ID (Required):" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="TxtPartID" Height="26" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="XClass:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" x:Name="TxtXClass" Height="26" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Text="Description / Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="5" x:Name="TxtDesc" Height="26" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="6" Text="Target BOM Type:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="7" x:Name="CboBomType" Height="26" Margin="0,0,0,10">
            <ComboBoxItem Content="DETAIL" IsSelected="True"/>
            <ComboBoxItem Content="PANEL"/>
        </ComboBox>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="Cancel" Width="70" Height="26" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Save to Master Lib" Width="130" Height="26" Background="#FF005E9E" Foreground="White" FontWeight="Bold" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>