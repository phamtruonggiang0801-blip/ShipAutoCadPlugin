<Window x:Class="ShipAutoCadPlugin.UI.FittingLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MacGregor Fitting Library" Height="680" Width="1300"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#FFF0F0F0" FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#FF0055A5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF004080"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Style.Resources>
                <VisualBrush x:Key="HelpBrush" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Padding="5,0,0,0" Text="Search by Part ID, Name, Desc, Originator, View (e.g., 'sheave 22')..."/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                </Trigger>
                <Trigger Property="Text" Value="">
                    <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFE8E8E8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFDEDEDE"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="FITTING CATALOG" FontSize="16" FontWeight="Bold" Foreground="#FF0055A5" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Mode:" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <RadioButton x:Name="RadioMasterMode" Content="Master Library" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Checked="RadioMode_Checked"/>
                <RadioButton x:Name="RadioProjectMode" Content="Project Library" Margin="0,0,20,0" VerticalAlignment="Center" Checked="RadioMode_Checked"/>
                
                <TextBlock Text="Project:" Margin="0,0,5,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtCurrentProject" Width="140" IsReadOnly="True" Background="#FFE8E8E8" Margin="0,0,5,0" VerticalContentAlignment="Center" ToolTip="Current Active Project"/>
                
                <Button x:Name="BtnLoadProject" Content="Load Project" Width="85" Height="26" Margin="0,0,5,0" Click="BtnLoadProject_Click"/>
                <Button x:Name="BtnCreateProject" Content="Create Project" Width="95" Height="26" Click="BtnCreateProject_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Global Search:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox Grid.Column="1" x:Name="TxtSearch" Style="{StaticResource SearchTextBoxStyle}" TextChanged="TxtSearch_TextChanged" ToolTip="Multi-keyword search is supported. Type keywords separated by space."/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#FFDEDEDE" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" BorderBrush="#FFDEDEDE" BorderThickness="0,0,0,1" Background="#FFE8E8E8">
                        <TextBlock Text="Categories (Group by Name)" FontWeight="SemiBold" Padding="8,6" Foreground="#FF333333"/>
                    </Border>
                    
                    <TreeView Grid.Row="1" x:Name="TreeCategories" SelectedItemChanged="TreeCategories_SelectedItemChanged" BorderThickness="0" Padding="5">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="📁 " Foreground="#FFDEB887"/>
                                    <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" Foreground="#FF333333"/>
                                    <TextBlock Text="{Binding CountLabel}" Foreground="#FF888888" Margin="5,0,0,0"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="#FFF0F0F0" Margin="2,0"/>

            <DataGrid Grid.Column="2" x:Name="GridCatalog" 
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="False" SelectionMode="Extended"
                      Background="White" BorderBrush="#FFDEDEDE" RowHeight="26"
                      CellEditEnding="GridCatalog_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding EntityType}" Width="Auto" IsReadOnly="True" FontWeight="SemiBold" Foreground="#FF005E9E"/>
                    <DataGridTextColumn Header="View / File Name" Binding="{Binding BlockName}" Width="Auto" Foreground="#FF555555" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Part Complete ID" Binding="{Binding PartNumber}" Width="Auto" FontWeight="Bold" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Title}" Width="Auto" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextWrapping" Value="Wrap"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextWrapping" Value="Wrap"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn x:Name="ColProjectPos" Header="Project Pos." Binding="{Binding ProjectPosNum, UpdateSourceTrigger=PropertyChanged}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#FFD32F2F"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <Trigger Property="IsReadOnly" Value="True">
                                        <Setter Property="Background" Value="#FFF0F0F0"/>
                                        <Setter Property="ToolTip" Value="Switch to Project Library to edit Position"/>
                                    </Trigger>
                                    <Trigger Property="IsReadOnly" Value="False">
                                        <Setter Property="Background" Value="#FFFFF9C4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="UoM" Binding="{Binding UoM}" Width="50" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Weight" Binding="{Binding Mass, StringFormat={}{0} kg}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Originator" Binding="{Binding Designer}" Width="Auto" IsReadOnly="True"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="GridCatalog_MouseDoubleClick"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="BtnAddFromCad" Content="➕ Add from CAD" Width="130" Margin="0,0,10,0" Click="BtnAddFromCad_Click" Background="#FF28A745" Foreground="White" FontWeight="Bold" Height="28"/>
                <Button x:Name="BtnManageAccessory" Content="🔗 Sub-BOM / Accessories" Width="180" Margin="0,0,10,0" Click="BtnManageAccessory_Click" FontWeight="SemiBold" Background="#FFE1E1E1" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnAutoAssignPos" Content="Auto-Assign Pos" Width="120" Margin="0,0,10,0" Click="BtnAutoAssignPos_Click"/>
                <Button x:Name="BtnRemoveSelected" Content="Remove Selected" Width="120" Margin="0,0,10,0" Click="BtnRemoveSelected_Click" Foreground="#FFD32F2F" FontWeight="SemiBold"/>
                <Button x:Name="BtnAddToProject" Content="Add to Project" Width="120" Margin="0,0,10,0" Click="BtnAddToProject_Click"/>
                <Button x:Name="BtnUpdateLibrary" Content="Push Update" Width="100" Margin="0,0,10,0" Click="BtnUpdateLibrary_Click"/>
                <Button x:Name="BtnRefresh" Content="Refresh" Width="70" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnInsert" Content="Insert to CAD" Width="120" Style="{StaticResource PrimaryButtonStyle}" Click="BtnInsert_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>