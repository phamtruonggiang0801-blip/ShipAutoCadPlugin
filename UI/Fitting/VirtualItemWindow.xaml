<Window x:Class="ShipAutoCadPlugin.UI.VirtualItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Virtual / Geometric Item" Height="520" Width="450"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#FFF2F2F2" FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF444444"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
        </Style>

        <Style x:Key="ReadOnlyTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#FFEAEAEA"/>
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Auto-Extracted Geometry Properties" BorderBrush="#FFCCCCCC" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Entity Type:"/>
                <TextBox x:Name="TxtEntityType" Grid.Row="0" Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Layer:"/>
                <TextBox x:Name="TxtLayer" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}" Margin="0,0,0,8" FontWeight="Bold" Foreground="#FF005E9E"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Color:"/>
                <TextBox x:Name="TxtColor" Grid.Row="2" Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Default UoM:"/>
                <TextBox x:Name="TxtUoM" Grid.Row="3" Grid.Column="1" Style="{StaticResource ReadOnlyTextBox}"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Item Metadata" BorderBrush="#FF005E9E" BorderThickness="1.5" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Part ID:" Foreground="#FFD32F2F"/>
                <TextBox x:Name="TxtPartID" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontWeight="Bold"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="XClass (Title):"/>
                <TextBox x:Name="TxtTitle" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:"/>
                <TextBox x:Name="TxtDesc" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Mass (kg):"/>
                <TextBox x:Name="TxtMass" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>
                
                <TextBlock Grid.Row="4" Grid.Column="0" Text="BOM Type:"/>
                <ComboBox x:Name="CboBomType" Grid.Row="4" Grid.Column="1" Height="26">
                    <ComboBoxItem Content="DETAIL" IsSelected="True"/>
                    <ComboBoxItem Content="PANEL"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click" Background="#FFE1E1E1" BorderBrush="#FFADADAD" Height="28"/>
            <Button x:Name="BtnSave" Content="Save to Master Library" Width="160" Click="BtnSave_Click" Background="#FF005E9E" Foreground="White" FontWeight="Bold" BorderBrush="#FF004C82" Height="28"/>
        </StackPanel>
    </Grid>
</Window>