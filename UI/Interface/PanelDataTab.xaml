<UserControl x:Class="ShipAutoCadPlugin.UI.PanelStructureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontSize="11">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
        <StackPanel TextElement.FontWeight="Normal">
            <GroupBox Header="GLOBAL VAULT EXCEL SYNC" Margin="5,0,5,10">
                <StackPanel>
                    <Grid Margin="0,2,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Name="TxtExcelPath" IsReadOnly="True" Background="#FFF9F9F9" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="..." Width="24" Click="BtnSelectExcel_Click"/>
                    </Grid>
                    <StackPanel Margin="0,2,0,8">
                        <CheckBox x:Name="ChkSyncSheet" Content="Sync Sheet &amp; Revision (Tab 1 &amp; 2)" IsChecked="True"/>
                        <CheckBox x:Name="ChkSyncPanel" Content="Sync Panel Engineering (Tab 3)" IsChecked="True"/>
                    </StackPanel>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Name="BtnPullExcel" Content="Pull Data" Click="BtnPullExcel_Click"/>
                        <Button Grid.Column="1" Name="BtnPushExcel" Content="Push Data" Click="BtnPushExcel_Click"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <Expander Header="PANEL AUTOMATION" IsExpanded="False">
                <StackPanel Margin="10,4">
                    <GroupBox Header="Deck Identification">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Deck No:" FontWeight="Normal" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Name="TxtDeckNumber" Text="6"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Guiding Mode">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Grid.Column="0" Name="RadGuide3" Content="Guide 3" IsChecked="True"/>
                            <RadioButton Grid.Column="1" Name="RadGuide2" Content="Guide 2"/>
                        </Grid>
                    </GroupBox>
                    <Grid Margin="0,2,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnAutoNamePanels" Grid.Column="0" Click="BtnAutoNamePanels_Click">
                            <TextBlock Text="Scan &amp; Name Panels" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Button>
                        <Button x:Name="BtnAddManualLugs" Grid.Column="1" Click="BtnAddManualLugs_Click">
                            <TextBlock Text="Add Point (Manual)" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="PLAN VIEW TOOLS" IsExpanded="True">
                <StackPanel Margin="10,4">
                    <Button x:Name="BtnOpenDashboard" Content="Open Panel Data" Height="28" Click="BtnOpenDashboard_Click"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnGenerateDetails" Grid.Column="0" Click="BtnGenerateDetails_Click">
                            <TextBlock Text="Generate Labels" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Button>
                        <Button x:Name="BtnUpdateDetailName" Grid.Column="1" Click="BtnUpdateDetailName_Click">
                            <TextBlock Text="Update by Proximity" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="DETAIL VIEW TOOLS" IsExpanded="False">
                <StackPanel Margin="10,4">
                    <CheckBox x:Name="ChkGlobalRevBump" Content="Global Revision Bump (Apply to all Sheets)"/>
                    <GroupBox Header="A1 Frame Operations">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnAddSheetContent" Grid.Column="0" Content="Sync &amp; Update Sheet" Click="BtnAddSheetContent_Click"/>
                            <Button x:Name="BtnCreateAmendment" Grid.Column="1" Content="Create Rev Block" Click="BtnCreateAmendment_Click"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Data Grid (Sheets &amp; Revs)">
                        <StackPanel>
                            <DataGrid Name="GridShared" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="GridShared_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sheet No" Binding="{Binding SheetNo}" Width="65" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Content" Binding="{Binding Content}" Width="110"/>
                                    <DataGridTextColumn Header="Rev" Binding="{Binding Rev}" Width="40"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="70"/>
                                    <DataGridTextColumn Header="Desc." Binding="{Binding AmendmentDescription}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <GridSplitter Height="4" HorizontalAlignment="Stretch" Background="#FFDEDEDE" Margin="0,5"/>
                            <DataGrid Name="GridHistory" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Delete Revision Block" Click="MenuDeleteRev_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Rev" Binding="{Binding Rev}" Width="40" FontWeight="Bold"/> 
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="70"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Name="BtnRefresh" Content="Refresh Table" HorizontalAlignment="Right" Click="BtnRefresh_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>