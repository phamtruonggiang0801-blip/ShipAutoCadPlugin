<Window x:Class="ShipAutoCadPlugin.UI.EngineeringDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Data &amp; Fitting Matrix" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0" FontFamily="Segoe UI" FontSize="12">
    
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF919191"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFDEDEDE"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FFDEDEDE"/>
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF9F9F9"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#FFDEDEDE"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="Button" x:Key="CadButtonStyle">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="#FFE0E0E0"/> 
            <Setter Property="BorderBrush" Value="#FF919191"/> 
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Normal"/> 
            <Setter Property="Foreground" Value="#FF111111"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE8E8E8"/>
                    <Setter Property="BorderBrush" Value="#FF555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" x:Name="BtnScanAndAudit" Content="Scan Drawing" 
                Style="{StaticResource CadButtonStyle}" Height="28" Margin="0,0,0,10"
                ToolTip="Select Master Blocks on CAD to extract Panel and Detail relationships" 
                Click="BtnScanAndAudit_Click"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="1. PANELS" BorderBrush="#FFDEDEDE" Padding="5">
                <DataGrid x:Name="GridMasterPanels" AutoGenerateColumns="False" CanUserAddRows="False" 
                          IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridMasterPanels_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Panel Name" Binding="{Binding Name}" Width="120"/>
                        <DataGridTextColumn Header="Area (m2)" Binding="{Binding Area}" Width="*"/>
                        
                        <DataGridTextColumn Header="Fitting Qty" Binding="{Binding FittingCount}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FittingCount}" Value="0">
                                            <Setter Property="Foreground" Value="#FF999999"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FittingCount, Converter={x:Null}}" Value="False">
                                            <Setter Property="Foreground" Value="#FF008000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="#FFDEDEDE" Margin="2,0"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="2. DETAILS" BorderBrush="#FFDEDEDE" Padding="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#FFF9F9F9" BorderBrush="#FFDEDEDE" BorderThickness="1,1,1,0" Padding="5,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/> 
                                    <ColumnDefinition Width="100"/> 
                                    <ColumnDefinition Width="*"/>   
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Object Name" FontWeight="Normal" Foreground="#FF333333" Margin="20,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="Qty" FontWeight="Normal" Foreground="#FF333333"/>
                            </Grid>
                        </Border>
                        
                        <TreeView x:Name="TreeDetails" Grid.Row="1" BorderThickness="1" BorderBrush="#FF919191" Background="White">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Border BorderBrush="#FFEEEEEE" BorderThickness="0,0,0,1" Padding="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250"/> 
                                                <ColumnDefinition Width="100"/> 
                                                <ColumnDefinition Width="*"/>   
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="0,0,10,0" Foreground="#FF333333" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Qty}" Margin="0,0,10,0" Foreground="#FF333333"/>
                                        </Grid>
                                    </Border>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="IsExpanded" Value="True"/> 
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Grid>
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#FFDEDEDE" Margin="0,5"/>

                <GroupBox Grid.Row="2" Header="3. FITTINGS (Synced from BOM Matrix)" BorderBrush="#FFDEDEDE" Padding="5">
                    <DataGrid x:Name="GridFittings" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#FF0055A5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="Fitting (Vault Name)" Binding="{Binding VaultName}" Width="150" FontWeight="SemiBold"/>
                            
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Part ID" Binding="{Binding PartId}" Width="100"/>
                            
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

            </Grid>
        </Grid>
    </Grid>
</Window>